{
  "name": "music-player",
  "version": "1.0.0",
  "description": "免费音乐播放器 - 支持多平台搜索与音质自动检测",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "public": "node server.js --public",
    "electron": "electron .",
    "build:exe": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "express": "^4.18.2",
    "localtunnel": "^2.0.2"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "railway": "github:railwayapp/railway-ts-sdk"
  },
  "build": {
    "appId": "com.musicbox.player",
    "productName": "MusicBox",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "server.js",
      "public/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": []
  }
}
